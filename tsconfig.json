{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "declaration": true,
    "outDir": "dist",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "charlie-fixes": ["./src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "design", "node_modules", "demo"]
}
